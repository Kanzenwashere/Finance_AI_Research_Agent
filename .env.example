# Copy to .env and fill in. The CLI and the web server both load this automatically.
ANTHROPIC_API_KEY=sk-ant-...

# --- Web demo guardrails (optional; sensible defaults shown) ---
# Per-IP cap on live meetings per rolling hour. Over it, a saved example run is served instead.
RATE_LIMIT_PER_HOUR=3
# Global cap on live meetings per day, across all visitors. Over it, the saved run is served.
DAILY_CAP=60
